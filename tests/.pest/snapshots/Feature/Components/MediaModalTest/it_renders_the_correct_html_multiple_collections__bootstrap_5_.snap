>
    <div class="mle-document-preview">
        <span 
        role="img" 
        aria-label="PDF document." 
        title="PDF document.">?</span>
        <div class="mle-document-info">
            <p>
                test.pdf
            </p>
            <p>
                1 KB
            </p>

            
                            <a href="/storage/3/test.pdf" target="_blank" class="mle-document-link" data-mle-document-link>
                    <span 
        role="img" 
        aria-label="PDF document." 
        title="PDF document.">?</span>
                    Download document
                </a>
            
                                                </div>
    </div>
</div>
                </div>
            </div>
                    <div
                class="mle-media-carousel-item carousel-item"
                data-mle-carousel-item
            >
                <div class="mle-media-carousel-item-container"
                                     >
                    <div 
    class="mle-video mle-media-preview-item" draggable="" data-bs-target="#test-media-modal-mod-mod-crs" data-bs-slide-to="3"
    id="test-media-modal-mod-3-media-viewer-video"
    data-mle-video
>
    <div class="mle-video-preview">
        <div class="mle-video-info">
            <p>
                test.mp4
            </p>
        </div>
        <video id="test-media-modal-mod-3-media-viewer-video" controls preload="metadata" data-mle-video>
            <source src="/storage/5/test.mp4" type="video/mp4">
            medialibrary-extensions::messages.your_browser_does_not_support_the_video_element
        </video>
    </div>
</div>
                </div>
            </div>
                    <div
                class="mle-media-carousel-item carousel-item"
                data-mle-carousel-item
            >
                <div class="mle-media-carousel-item-container"
                                     >
                    <div 
    class="mle-audio mle-media-preview-item" draggable="" data-bs-target="#test-media-modal-mod-mod-crs" data-bs-slide-to="4"
    id="test-media-modal-mod-4-media-viewer-audio"
>
    <div class="mle-audio-preview">
        <div class="mle-audio-info">
            <p>
                test.mp3
            </p>
        </div>
        <audio id="test-media-modal-mod-4-media-viewer-audio" controls data-mle-audio>
            <source src="/storage/4/test.mp3" type="audio/mpeg">
            Your browser does not support the audio element.
        </audio>
    </div>
</div>                </div>
            </div>
            </div>

    
    <button
