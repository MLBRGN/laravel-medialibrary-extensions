                                    <div class="mle-conditional-form mle-media-manager-upload-form" data-mle-xhr-form="data-mle-xhr-form" id="test-media-modal-upload-form" data-xhr-method="post">
        <label for="test-media-modal-media-input" class="mle-label form-label">Upload</label>
    <input
        id="test-media-modal-media-input"
        data-mle-media-input
        accept="image/jpeg, image/png, image/gif, image/bmp, image/webp, image/heic, image/avif"
        type="file"
        class="mle-input mle-form-control form-control mb-2"
                    name="media"
                        >
        <span class="mle-form-text form-text">
            Supported files: JPEG, PNG, GIF, BMP, WebP, HEIC, AVIF • up to 16 MB • 320×160–7040×3960 px.
        </span>
                                        <input
                type="hidden"
                name="collections[image]"
                value="images">
                <input
        type="hidden"
        name="single_media_id"
        value="">
    <input 
        type="hidden" 
        name="temporary_upload_mode" 
        value="true">
    <input
        type="hidden"
        name="model_type"
        value="Mlbrgn\MediaLibraryExtensions\Tests\Models\Blog">
    <input
        type="hidden"
        name="model_id"
        value="">
    <input
        type="hidden"
        name="base_id"
        value="test-media-modal">
    <input
        type="hidden"
        name="client_token"
        value="<ULID>">
    <input type="hidden"
           name="data_source"
           value="default">
    <button
        type="button"
        class="mle-button mle-button-submit btn btn-primary d-block"
        data-mle-action="upload-media"
        data-mle-media-upload-button
            >
        Upload medium
    </button>
