<div 
    class="mle-video"
    id="test-video-video"
    data-mle-video
>
    <div class="mle-video-preview">
        <div class="mle-video-info">
            <p>
                test.mp3
            </p>
        </div>
        <video id="test-video-video" controls preload="metadata" data-mle-video>
            <source src="/storage/1/test.mp3" type="audio/mpeg">
            medialibrary-extensions::messages.your_browser_does_not_support_the_video_element
        </video>
    </div>
</div>
