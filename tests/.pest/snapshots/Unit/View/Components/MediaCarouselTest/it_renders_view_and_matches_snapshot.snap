        <span 
        role="img" 
        aria-label="Previous" 
        title="Previous">❓</span>
        </span>
        <span class="mle-visually-hidden">Previous</span>
    </button>
    <button
        class="mle-media-carousel-control-next carousel-control-next disabled"
        type="button"
        data-bs-target="#media-carousel-crs"
        data-bs-slide="next"
        title="Next"
    >
