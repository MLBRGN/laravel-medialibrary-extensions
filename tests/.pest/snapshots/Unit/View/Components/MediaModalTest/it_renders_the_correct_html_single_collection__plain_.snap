<div
    class="mle-component mle-theme-plain mle-media-modal mle-modal mle-fade"
    id="test-media-modal-mod"
    tabindex="-1"
    role="dialog"
            aria-labelledby="test-media-modal-mod-title"
        aria-hidden="true"
            data-mle-autoplay=""
        data-mle-modal
    data-mle-media-modal
    data-test="media-modal"
>
    <div class="mle-modal-dialog mle-media-modal-dialog">
        <div class="mle-modal-content mle-media-modal-content">
                            <h1 class="mle-modal-title mle-media-modal-title mle-visually-hidden" id="test-media-modal-mod-title">test</h1>
                        <div class="mle-modal-body mle-media-modal-body">
                <button
                    type="button"
                    class="mle-modal-close-button mle-media-modal-close-button"
                    data-mle-modal-close
                    aria-label="Sluit"
                    title="Close"
                    data-test="media-modal-close-button"
                >
                    <span 
        role="img" 
        aria-label="Close" 
        title="Close">❓</span>
                </button>
                
                <div id="test-media-modal-mod-crs"
     class="mle-component mle-theme-plain mle-media-carousel mle-media-carousel-plain mle-width-100 mle-height-100 mle-width-100 mle-height-100" instance-id="E3642AD197F92C6D1BF5D78226"
    data-mle-carousel
    data-mle-carousel-id="test-media-modal-mod-crs"
    tabindex="-1"
        data-mle-carousel-effect="slide"
>







    
    <div
        class="mle-media-carousel-indicators"
        data-mle-carousel-indicators
    >
                    <button
                type="button"
                data-mle-slide-to="0"
                class="active"
                 
                    aria-current="true" 
                                aria-label="Slide to 1">
            </button>
                    <button
                type="button"
                data-mle-slide-to="1"
                class=""
                                aria-label="Slide to 2">
            </button>
            </div>

    
    <div class="mle-media-carousel-inner">
                    <div
                class="mle-media-carousel-item active"
                data-mle-carousel-item
            >
                <div class="mle-media-carousel-item-container"
                                     >
                    <img
        class="mle-media-preview-item mle-image-responsive" draggable="false"
        src="/media/1/test.jpg"
                        alt=""
         loading="lazy"         data-mle-image
        data-test="media-preview-image"
    >
                </div>
            </div>
                    <div
                class="mle-media-carousel-item"
                data-mle-carousel-item
            >
                <div class="mle-media-carousel-item-container"
                                     >
                    <img
        class="mle-media-preview-item mle-image-responsive" draggable="false"
        src="/media/2/test2.jpg"
                        alt=""
         loading="lazy"         data-mle-image
        data-test="media-preview-image"
    >
                </div>
            </div>
            </div>

    
    <button
        class="mle-media-carousel-control-prev"
        type="button"
        data-mle-slide="prev"
        title="Previous"
    >
        <span class="mle-media-carousel-control-prev-icon" aria-hidden="true">
        <span 
        role="img" 
        aria-label="Previous" 
        title="Previous">❓</span>
        </span>
        <span class="mle-visually-hidden">Previous</span>
    </button>
    <button
        class="mle-media-carousel-control-next"
        type="button"
        data-mle-slide="next"
        title="Next"
    >
        <span class="mle-media-carousel-control-next-icon" aria-hidden="true">
            <span 
        role="img" 
        aria-label="Next" 
        title="Next">❓</span>
        </span>
        <span class="mle-visually-hidden">Next</span>
    </button>





</div>
